  title = {{The Born--Infeld Saturation Margin of the Chiral Modulus: Antisymmetric Structure and the Reduction of the Generation Split to a Lorentzian Genus}},
  journal = {Working paper},
  year = {2026},
  note = {Fermionic matter sub-programme companion note to PRS. Discharges the first PRS open deliverable: definition of the Lorentzian saturation functional $\mathcal{B}_{\mathrm{sat}}(s)$ along the $J_\Pi$-odd modulus controlling the three-generation split coefficient $u$. Three results: (i)~antisymmetry lemma --- the generation modulus is $J_\Pi$-odd and the symmetric square $M = F_\chi F_\chi$ is $J_\Pi$-even from birth, so the primary modulus variable must be an antisymmetric chiral two-form $F_{\chi,\mu\nu}(s)$; (ii)~$\mathcal{B}_{\mathrm{sat}}(s)$ defined as the Born--Infeld determinantal saturation margin of this two-form, with sign locked by the admissibility role of $\mathcal{B}_{\mathrm{sat}}$ (axiom A4 selects saturated minima), not by Maxwell weak-field matching; (iii)~genus reduction --- $\mu_\chi := \partial_s^2 \mathcal{B}_{\mathrm{sat}}(0) = \tfrac{1}{2} P_{\chi,\mu\nu} P_\chi^{\mu\nu}$, so the existence and stability of the split are governed entirely by the Lorentzian genus of the chiral polarisation $P_\chi$ in the effective metric $g^{\mu\nu} = 2\eta^{\mu\nu}$. In the Schur-transverse branch closed in PRS the chiral polarisation is electric in the effective Lorentzian metric, so $\mu_\chi^2 < 0$ and the $J_\Pi$-symmetric branch is unstable, the split opening spontaneously; the absolute amplitude and the boundary-versus-interior normalisation are left to the downstream construction,
 \doi{10.5281/zenodo.20633931}}
}

@misc{Beau2026ebj,
  author = {Beau, J\'er\^ome},
  title = {{The Constrained Jet of the Lorentzian Eliminated Block and the Chiral Generator}},
  journal = {Working paper},
  year = {2026},
  note = {Fermionic matter sub-programme companion note. Constrains the eliminated-block jet $1-P(s) = Q_0 + sQ_1 + s^2Q_2 + O(s^3)$: $Q_1 = [A, Q_0]$ is a purely off-diagonal Grassmann tangent and $Q_2$ diagonal blocks are pinned to $Q_1^2$ with opposite signs; parity propagation gives $u(s) = s\,\langle J_3, \{E_0, E_1\}\rangle/\langle J_3, J_3\rangle + O(s^3)$ with $v\equiv0$ for phase-free data. Identifies the chiral generator as the transported equivariance defect rate: $[\Pi_{J_\Pi\text{-odd}}(1-P)]_{LL} = \tfrac12\Delta_\chi(P)$, $[\Pi_{J_\Pi\text{-odd}}\dot Q(0)]_{LL} = \tfrac12\partial_s\Delta_\chi(P)|_0$, reducing the value question to the admissible normalisation of $\partial_s\Delta_\chi(P)|_0$,
 \doi{10.5281/zenodo.20763532}}
}

